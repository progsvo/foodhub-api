import "dotenv/config";
import { prisma } from "../lib/prisma";
import { UserRole } from "../middleware/auth";

const AUTH_URL = process.env.BETTER_AUTH_URL ?? "http://localhost:5000";
const APP_URL = process.env.APP_URL ?? "http://localhost:3000";

const SEED_PASSWORD = "password123";

const usersToCreate = [
  { name: "Admin User", email: "admin@foodhub.com", role: UserRole.ADMIN },
  { name: "John Customer", email: "customer@foodhub.com", role: UserRole.CUSTOMER },
  { name: "Maria's Kitchen", email: "maria@foodhub.com", role: UserRole.PROVIDER },
  { name: "Bella Restaurant", email: "bella@foodhub.com", role: UserRole.PROVIDER },
];

async function createUsers() {
  const created: Record<string, string> = {};

  for (const u of usersToCreate) {
    const existing = await prisma.user.findUnique({ where: { email: u.email } });
    if (existing) {
      created[u.email] = existing.id;
      console.log(`User ${u.email} already exists`);
      continue;
    }

    const res = await fetch(`${AUTH_URL}/api/auth/sign-up/email`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Origin: APP_URL,
      },
      body: JSON.stringify({
        name: u.name,
        email: u.email,
        role: u.role,
        password: SEED_PASSWORD,
      }),
    });

    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      console.error(`Failed to create ${u.email}:`, err);
      continue;
    }

    const user = await prisma.user.findUnique({ where: { email: u.email } });
    if (user) {
      await prisma.user.update({
        where: { id: user.id },
        data: { emailVerified: true },
      });
      created[u.email] = user.id;
      console.log(`Created user: ${u.email}`);
    }
  }

  return created;
}

